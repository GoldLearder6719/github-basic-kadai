      "source": [
        "top_side = 10     # 上辺：10cm\n",
        "bottom_side = 20  # 下辺：20cm\n",
        "hight = 5         # 高さ：5cm\n",
        "\n",
        "area = (top_side + bottom_side) * hight / 2\n",
        "     # 公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "print(f\"台形の面積の計算結果は{area}cm²です。\")"
      ]
    }
  ]
}